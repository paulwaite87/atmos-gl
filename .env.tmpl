# Copy this file to your own local .env then paste your API keys below.
# For AIS API access to shipping data streams.
# Go to https://aisstream.io/documentation
AIS_API_KEY=<api_key_here>
# OpenWeather API access to lightning strikes data.
# Go to https://openweathermap.org
OPENWEATHER_API_KEY=<api_key_here>
# Map tiles API Key
MAPTILER_API_KEY=<api_key_here>
# NASA FIRMS active-fire data access.
# Go to https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_API_KEY=<api_key_here>
# Change these to your own user/group IDs
UID=
GID=
GITHUB_TOKEN=
