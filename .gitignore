# --- Project Specific (Data & Config) ---
# Ignore various data files
data/*
files/
# The live, locally-running config -- config/atmos-gl.json.tmpl is the tracked
# template; this file is where settings actually get changed/tested day to day.
# See CLAUDE.md's "Settings changes" section for the tmpl <-> live workflow.
/config/atmos-gl.json

# Ignore environment secrets
.env
.env.local

# --- Python ---
.idea/
.idea/workspace.xml
.venv/
.venv_wallpaper/
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
nohup.out

# --- Build & Packaging ---
dist/
build/
*.egg-info/

# --- Node (JS test tooling only; ui/ itself has no build step) ---
node_modules/

# --- Docker ---
docker-compose.override.yml

# --- OS & IDEs ---
.DS_Store
Thumbs.db
.vscode/
.idea/
.claude/
*.swp
*~


# --- Ship Data / XPlanet Artifacts ---
